{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "package": {
    "productName": "Jarvis Work",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devPath": "http://127.0.0.1:5173",
    "distDir": "../frontend/dist"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": [
        "nsis"
      ],
      "identifier": "com.jarvis.work",
      "windows": {
        "digestAlgorithm": "sha256"
      }
    },
    "windows": [
      {
        "title": "Jarvis Work",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  }
}